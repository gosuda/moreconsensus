{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gosuda.org/moreconsensus/schemas/kvnode-capacity-evidence-v2.json",
  "title": "kvnode native Darwin capacity characterization evidence v2",
  "description": "Fail-closed evidence for one bounded, same-host Darwin arm64 capacity characterization. This schema does not represent a production-capacity certification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "verifier_version",
    "evidence_class",
    "production_capacity_certification",
    "claim_scope",
    "target",
    "native_environment",
    "nodes",
    "resource_envelope",
    "sampling",
    "summary",
    "artifacts",
    "independent_review",
    "nonclaims"
  ],
  "properties": {
    "schema": {
      "const": "https://gosuda.org/moreconsensus/schemas/kvnode-capacity-evidence-v2.json"
    },
    "verifier_version": {
      "const": "2.0.0"
    },
    "evidence_class": {
      "const": "workstation-capacity-characterization"
    },
    "production_capacity_certification": {
      "const": false
    },
    "claim_scope": {
      "const": "native-darwin-same-host-bounded-characterization"
    },
    "target": {
      "$ref": "#/$defs/targetBinding"
    },
    "native_environment": {
      "$ref": "#/$defs/nativeEnvironment"
    },
    "nodes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "resource_envelope": {
      "$ref": "#/$defs/resourceEnvelope"
    },
    "sampling": {
      "$ref": "#/$defs/sampling"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "artifacts": {
      "type": "array",
      "minItems": 8,
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "independent_review": {
      "$ref": "#/$defs/review"
    },
    "nonclaims": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,9})?Z$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[A-Za-z0-9._/-]+$",
      "minLength": 1,
      "maxLength": 512
    },
    "targetBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "release_id",
        "source_revision",
        "binary_sha256",
        "environment_profile"
      ],
      "properties": {
        "target_id": {
          "const": "mc-kv-darwin24-arm64-launchd-3n-r1"
        },
        "release_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
        },
        "source_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "binary_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "environment_profile": {
          "const": "native-darwin24-arm64-launchd-system-domain-v1"
        }
      }
    },
    "nativeEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "architecture",
        "binary_format",
        "execution_mode",
        "supervisor",
        "launchd_domain",
        "filesystem",
        "network_scope",
        "tls_scope",
        "host_id",
        "os_version",
        "kernel_release",
        "tls_ca_sha256"
      ],
      "properties": {
        "platform": {
          "const": "darwin"
        },
        "architecture": {
          "const": "arm64"
        },
        "binary_format": {
          "const": "mach-o-64-arm64"
        },
        "execution_mode": {
          "const": "native"
        },
        "supervisor": {
          "const": "launchd"
        },
        "launchd_domain": {
          "const": "system"
        },
        "filesystem": {
          "const": "apfs"
        },
        "network_scope": {
          "const": "same-host-loopback"
        },
        "tls_scope": {
          "const": "server-auth-only"
        },
        "host_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "os_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "kernel_release": {
          "type": "string",
          "minLength": 1,
          "pattern": "^24\\.[0-9]+\\.[0-9]+$",
          "maxLength": 128
        },
        "tls_ca_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "launchd_label",
        "pid",
        "process_start_token",
        "executable_path",
        "data_dir",
        "client_url",
        "admin_url"
      ],
      "properties": {
        "node_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "launchd_label": {
          "type": "string",
          "pattern": "^org\\.gosuda\\.moreconsensus\\.kvnode\\.[123]$"
        },
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "process_start_token": {
          "type": "integer",
          "minimum": 1
        },
        "executable_path": {
          "type": "string",
          "pattern": "^/",
          "maxLength": 1024
        },
        "data_dir": {
          "type": "string",
          "pattern": "^/",
          "maxLength": 1024
        },
        "client_url": {
          "type": "string",
          "pattern": "^https://127\\.0\\.0\\.1:[0-9]{1,5}$"
        },
        "admin_url": {
          "type": "string",
          "pattern": "^https://127\\.0\\.0\\.1:[0-9]{1,5}$"
        }
      }
    },
    "limit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "limit"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "enum": [
            "percent",
            "bytes",
            "count",
            "nanoseconds",
            "operations-per-second"
          ]
        },
        "limit": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "nonnegativeLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "limit"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "enum": [
            "percent",
            "bytes",
            "count",
            "nanoseconds",
            "operations-per-second"
          ]
        },
        "limit": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "observationalIsolationLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "limit",
        "isolation_status",
        "enforcement_artifact"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "enum": [
            "percent",
            "bytes"
          ]
        },
        "limit": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "isolation_status": {
          "const": "none-observation-only"
        },
        "enforcement_artifact": {
          "type": "null"
        }
      }
    },
    "resourceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed",
        "approved_before_run_utc",
        "plan_sha256",
        "cpu",
        "memory",
        "open_fds",
        "apfs_allocated_growth",
        "disk_latency_p99",
        "request_throughput_minimum",
        "request_latency_p99",
        "request_error_rate_maximum_percent",
        "send_queue_depth"
      ],
      "properties": {
        "observed": {
          "const": true
        },
        "approved_before_run_utc": {
          "$ref": "#/$defs/utc"
        },
        "plan_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "cpu": {
          "allOf": [
            {
              "$ref": "#/$defs/observationalIsolationLimit"
            },
            {
              "type": "object",
              "required": [
                "isolation_status",
                "enforcement_artifact"
              ],
              "properties": {
                "unit": {
                  "const": "percent"
                },
                "isolation_status": {
                  "const": "none-observation-only"
                },
                "enforcement_artifact": {
                  "type": "null"
                }
              }
            }
          ]
        },
        "memory": {
          "allOf": [
            {
              "$ref": "#/$defs/observationalIsolationLimit"
            },
            {
              "type": "object",
              "required": [
                "isolation_status",
                "enforcement_artifact"
              ],
              "properties": {
                "unit": {
                  "const": "bytes"
                },
                "isolation_status": {
                  "const": "none-observation-only"
                },
                "enforcement_artifact": {
                  "type": "null"
                }
              }
            }
          ]
        },
        "open_fds": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "count"
                }
              }
            }
          ]
        },
        "apfs_allocated_growth": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "bytes"
                }
              }
            }
          ]
        },
        "disk_latency_p99": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "nanoseconds"
                }
              }
            }
          ]
        },
        "request_throughput_minimum": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "operations-per-second"
                }
              }
            }
          ]
        },
        "request_latency_p99": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "nanoseconds"
                }
              }
            }
          ]
        },
        "request_error_rate_maximum_percent": {
          "allOf": [
            {
              "$ref": "#/$defs/nonnegativeLimit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "percent"
                },
                "limit": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                }
              }
            }
          ]
        },
        "send_queue_depth": {
          "allOf": [
            {
              "$ref": "#/$defs/limit"
            },
            {
              "type": "object",
              "properties": {
                "unit": {
                  "const": "count"
                }
              }
            }
          ]
        }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interval_seconds",
        "started_utc",
        "completed_utc",
        "phase_order",
        "measurement_phase_order",
        "sample_count",
        "sample_provenance"
      ],
      "properties": {
        "interval_seconds": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 10
        },
        "started_utc": {
          "$ref": "#/$defs/utc"
        },
        "completed_utc": {
          "$ref": "#/$defs/utc"
        },
        "phase_order": {
          "const": [
            "warmup",
            "steady",
            "concurrent",
            "saturation",
            "recovery-observation"
          ]
        },
        "measurement_phase_order": {
          "const": [
            "steady",
            "concurrent",
            "saturation",
            "recovery-observation"
          ]
        },
        "sample_count": {
          "type": "integer",
          "minimum": 10
        },
        "sample_provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "process_rusage",
            "fd_count",
            "disk_latency",
            "apfs_allocated",
            "apfs_logical",
            "readiness",
            "metrics"
          ],
          "properties": {
            "process_rusage": {
              "const": "darwin-libproc-proc_pid_rusage-v2"
            },
            "fd_count": {
              "const": "darwin-lsof-numeric-f-field-only"
            },
            "disk_latency": {
              "const": "darwin-apfs-fsync-probe-per-data-dir"
            },
            "apfs_allocated": {
              "const": "darwin-du-sk-times-1024"
            },
            "apfs_logical": {
              "const": "darwin-du-sk-A-times-1024"
            },
            "readiness": {
              "const": "ca-verified-https-readyz"
            },
            "metrics": {
              "const": "ca-verified-https-metrics"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding",
        "warmup_attempts",
        "measurement_attempts",
        "measurement_successes",
        "measurement_errors",
        "measurement_error_rate_percent",
        "measurement_throughput_operations_per_second",
        "successful_request_latency_p50_ns",
        "successful_request_latency_p95_ns",
        "successful_request_latency_p99_ns",
        "max_cpu_utilization_percent",
        "max_rss_bytes",
        "observed_peak_rss_bytes",
        "max_open_fd_count",
        "disk_read_bytes",
        "disk_written_bytes",
        "disk_latency_p99_ns",
        "max_apfs_allocated_growth_bytes",
        "max_send_queue_depth",
        "ready_failure_count",
        "process_restart_count",
        "thresholds_passed"
      ],
      "properties": {
        "binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target",
            "verifier_version"
          ],
          "properties": {
            "target": {
              "$ref": "#/$defs/targetBinding"
            },
            "verifier_version": {
              "const": "2.0.0"
            }
          }
        },
        "warmup_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "measurement_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "measurement_successes": {
          "type": "integer",
          "minimum": 0
        },
        "measurement_errors": {
          "type": "integer",
          "minimum": 0
        },
        "measurement_error_rate_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "measurement_throughput_operations_per_second": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "successful_request_latency_p50_ns": {
          "type": "integer",
          "minimum": 1
        },
        "successful_request_latency_p95_ns": {
          "type": "integer",
          "minimum": 1
        },
        "successful_request_latency_p99_ns": {
          "type": "integer",
          "minimum": 1
        },
        "max_cpu_utilization_percent": {
          "type": "number",
          "minimum": 0
        },
        "max_rss_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "observed_peak_rss_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_open_fd_count": {
          "type": "integer",
          "minimum": 1
        },
        "disk_read_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "disk_written_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "disk_latency_p99_ns": {
          "type": "integer",
          "minimum": 1
        },
        "max_apfs_allocated_growth_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "max_send_queue_depth": {
          "type": "integer",
          "minimum": 0
        },
        "ready_failure_count": {
          "const": 0
        },
        "process_restart_count": {
          "const": 0
        },
        "thresholds_passed": {
          "const": true
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "environment-observations",
            "pre-run-plan",
            "phase-windows",
            "request-samples",
            "process-samples",
            "disk-latency-raw",
            "disk-latency-samples",
            "measurement"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_identity",
        "operator_identity",
        "decision",
        "reviewed_at_utc",
        "artifact_path",
        "artifact_sha256",
        "measurement_sha256"
      ],
      "properties": {
        "reviewer_identity": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "operator_identity": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "decision": {
          "const": "approved-workstation-characterization"
        },
        "reviewed_at_utc": {
          "$ref": "#/$defs/utc"
        },
        "artifact_path": {
          "$ref": "#/$defs/relativePath"
        },
        "artifact_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "measurement_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
