{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gosuda.org/moreconsensus/schemas/kvnode-production-capacity-certification-v2.json",
  "title": "kvnode target-bound production capacity certification v2",
  "description": "Fail-closed certification for a declared native Darwin same-host support envelope, multiple deterministic repetitions, raw observations, externally approved thresholds, and an external RSA-SHA256 approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "verifier_version",
    "evidence_class",
    "evidence_mode",
    "production_capacity_certification",
    "claim_scope",
    "release_claim",
    "operator_identity",
    "target",
    "native_environment",
    "support_envelope",
    "thresholds",
    "repetition_count",
    "repetition_summaries",
    "raw_artifacts",
    "campaign",
    "binary",
    "intermediate",
    "approval"
  ],
  "properties": {
    "schema": {
      "const": "https://gosuda.org/moreconsensus/schemas/kvnode-production-capacity-certification-v2.json"
    },
    "verifier_version": {
      "const": "2.0.0"
    },
    "evidence_class": {
      "const": "production-capacity-certification"
    },
    "evidence_mode": {
      "const": "target"
    },
    "production_capacity_certification": {
      "const": true
    },
    "claim_scope": {
      "const": "declared-native-darwin-same-host-support-envelope"
    },
    "release_claim": {
      "const": "target-bound-production-capacity-envelope-certified"
    },
    "operator_identity": {
      "$ref": "#/$defs/identity"
    },
    "target": {
      "$ref": "#/$defs/targetBinding"
    },
    "native_environment": {
      "$ref": "#/$defs/nativeEnvironment"
    },
    "support_envelope": {
      "$ref": "#/$defs/supportEnvelope"
    },
    "thresholds": {
      "$ref": "#/$defs/thresholds"
    },
    "repetition_count": {
      "type": "integer",
      "minimum": 3,
      "maximum": 20
    },
    "repetition_summaries": {
      "type": "array",
      "minItems": 3,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/repetitionSummary"
      }
    },
    "raw_artifacts": {
      "type": "array",
      "minItems": 10,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "campaign": {
      "$ref": "#/$defs/artifact"
    },
    "binary": {
      "$ref": "#/$defs/artifact"
    },
    "intermediate": {
      "$ref": "#/$defs/artifact"
    },
    "approval": {
      "$ref": "#/$defs/approval"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,9})?Z$"
    },
    "identity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\r\\n\\u0000]+$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[A-Za-z0-9._/-]+$"
    },
    "targetBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "release_id",
        "source_revision",
        "binary_sha256",
        "environment_profile"
      ],
      "properties": {
        "target_id": {
          "const": "mc-kv-darwin24-arm64-launchd-3n-r1"
        },
        "release_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
        },
        "source_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "binary_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "environment_profile": {
          "const": "native-darwin24-arm64-launchd-system-domain-v1"
        }
      }
    },
    "nativeEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "architecture",
        "binary_format",
        "execution_mode",
        "supervisor",
        "launchd_domain",
        "filesystem",
        "network_scope",
        "tls_scope",
        "host_id",
        "os_version",
        "kernel_release",
        "tls_ca_sha256"
      ],
      "properties": {
        "platform": { "const": "darwin" },
        "architecture": { "const": "arm64" },
        "binary_format": { "const": "mach-o-64-arm64" },
        "execution_mode": { "const": "native" },
        "supervisor": { "const": "launchd" },
        "launchd_domain": { "const": "system" },
        "filesystem": { "const": "apfs" },
        "network_scope": { "const": "same-host-loopback" },
        "tls_scope": { "const": "server-auth-only" },
        "host_id": { "$ref": "#/$defs/identity" },
        "os_version": { "$ref": "#/$defs/identity" },
        "kernel_release": {
          "type": "string",
          "pattern": "^24\\.[0-9]+\\.[0-9]+$"
        },
        "tls_ca_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "supportEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topology", "workload", "isolation"],
      "properties": {
        "topology": {
          "type": "object",
          "additionalProperties": false,
          "required": ["node_count", "host_scope", "network_scope", "supervisor", "filesystem"],
          "properties": {
            "node_count": { "const": 3 },
            "host_scope": { "const": "same-host" },
            "network_scope": { "const": "loopback" },
            "supervisor": { "const": "launchd-system" },
            "filesystem": { "const": "apfs" }
          }
        },
        "workload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "operation_sequence",
            "key_seed",
            "key_count",
            "value_bytes",
            "warmup_operations",
            "measurement_operations",
            "concurrency"
          ],
          "properties": {
            "name": { "type": "string", "minLength": 1, "maxLength": 128 },
            "operation_sequence": {
              "const": ["put", "get", "scan"]
            },
            "key_seed": { "type": "string", "minLength": 1, "maxLength": 128 },
            "key_count": { "type": "integer", "minimum": 1 },
            "value_bytes": { "type": "integer", "minimum": 1 },
            "warmup_operations": { "type": "integer", "minimum": 1 },
            "measurement_operations": { "type": "integer", "minimum": 1 },
            "concurrency": { "type": "integer", "minimum": 1, "maximum": 64 }
          }
        },
        "isolation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dedicated_host_required",
            "virtualization_forbidden",
            "ac_power_required",
            "sleep_forbidden",
            "competing_workloads_forbidden"
          ],
          "properties": {
            "dedicated_host_required": { "const": true },
            "virtualization_forbidden": { "const": true },
            "ac_power_required": { "const": true },
            "sleep_forbidden": { "const": true },
            "competing_workloads_forbidden": { "const": true }
          }
        }
      }
    },
    "limit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "direction", "limit"],
      "properties": {
        "unit": {
          "enum": ["operations-per-second", "nanoseconds", "bytes", "count", "percent"]
        },
        "direction": {
          "enum": ["minimum", "maximum"]
        },
        "limit": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "throughput",
        "request_latency_p99",
        "rss",
        "open_fds",
        "disk_allocated_growth",
        "disk_written",
        "fsync_latency_p99",
        "process_cpu",
        "system_cpu",
        "memory_pressure",
        "filesystem_free",
        "request_error_rate"
      ],
      "properties": {
        "throughput": { "$ref": "#/$defs/limit" },
        "request_latency_p99": { "$ref": "#/$defs/limit" },
        "rss": { "$ref": "#/$defs/limit" },
        "open_fds": { "$ref": "#/$defs/limit" },
        "disk_allocated_growth": { "$ref": "#/$defs/limit" },
        "disk_written": { "$ref": "#/$defs/limit" },
        "fsync_latency_p99": { "$ref": "#/$defs/limit" },
        "process_cpu": { "$ref": "#/$defs/limit" },
        "system_cpu": { "$ref": "#/$defs/limit" },
        "memory_pressure": { "$ref": "#/$defs/limit" },
        "filesystem_free": { "$ref": "#/$defs/limit" },
        "request_error_rate": { "$ref": "#/$defs/limit" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256", "size_bytes"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "repetitionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repetition_id",
        "sequence",
        "warmup_attempts",
        "measurement_attempts",
        "measurement_successes",
        "measurement_errors",
        "measurement_error_rate_percent",
        "measurement_throughput_operations_per_second",
        "request_latency_p99_ns",
        "max_rss_bytes",
        "max_open_fd_count",
        "max_disk_allocated_growth_bytes",
        "disk_written_bytes",
        "fsync_latency_p99_ns",
        "max_process_cpu_percent",
        "max_system_cpu_percent",
        "max_memory_pressure_percent",
        "min_filesystem_free_bytes",
        "thresholds_passed"
      ],
      "properties": {
        "repetition_id": { "type": "string", "pattern": "^repetition-[0-9]{3}$" },
        "sequence": { "type": "integer", "minimum": 1 },
        "warmup_attempts": { "type": "integer", "minimum": 1 },
        "measurement_attempts": { "type": "integer", "minimum": 1 },
        "measurement_successes": { "type": "integer", "minimum": 1 },
        "measurement_errors": { "type": "integer", "minimum": 0 },
        "measurement_error_rate_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "measurement_throughput_operations_per_second": { "type": "number", "exclusiveMinimum": 0 },
        "request_latency_p99_ns": { "type": "integer", "minimum": 1 },
        "max_rss_bytes": { "type": "integer", "minimum": 1 },
        "max_open_fd_count": { "type": "integer", "minimum": 1 },
        "max_disk_allocated_growth_bytes": { "type": "integer", "minimum": 0 },
        "disk_written_bytes": { "type": "integer", "minimum": 0 },
        "fsync_latency_p99_ns": { "type": "integer", "minimum": 1 },
        "max_process_cpu_percent": { "type": "number", "minimum": 0 },
        "max_system_cpu_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "max_memory_pressure_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "min_filesystem_free_bytes": { "type": "integer", "minimum": 1 },
        "thresholds_passed": { "const": true }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approver_identity",
        "approver_organization",
        "decision",
        "signed_at_utc",
        "signature_algorithm",
        "approval_artifact",
        "trust_root_artifact",
        "signature_artifact"
      ],
      "properties": {
        "approver_identity": { "$ref": "#/$defs/identity" },
        "approver_organization": { "$ref": "#/$defs/identity" },
        "decision": { "const": "approved-production-capacity-certification" },
        "signed_at_utc": { "$ref": "#/$defs/utc" },
        "signature_algorithm": { "const": "rsa-sha256" },
        "approval_artifact": { "$ref": "#/$defs/artifact" },
        "trust_root_artifact": { "$ref": "#/$defs/artifact" },
        "signature_artifact": { "$ref": "#/$defs/artifact" }
      }
    }
  }
}
