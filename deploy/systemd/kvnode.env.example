# Example/operator material for kvnode@.service.
# This is not a verified production deployment environment.
# Copy this file to /etc/kvnode/node1.env, /etc/kvnode/node2.env, or
# /etc/kvnode/node3.env and change the per-instance values below.
# The file is parsed by systemd as an EnvironmentFile, not as a shell script.

# Variables consumed by kvnode@.service:
# - KVNODE_ID: numeric EPaxos/KV node id passed to -id.
# - KVNODE_CLIENT_LISTEN: client HTTP listener passed to -listen.
# - KVNODE_PEER_LISTEN: peer replication HTTP listener passed to -peer-listen.
# - KVNODE_ADMIN_LISTEN: administrative HTTP listener passed to -admin-listen.
# - KVNODE_DATA_DIR: durable Pebble data directory passed to -data.
# - KVNODE_PEERS: complete comma-separated id=peer-url map passed to -peers.
# - KVNODE_REQUEST_DEADLINE_MS: client-facing deadline budget in milliseconds.
# - KVNODE_PEER_DEADLINE_MS: peer-replication deadline budget in milliseconds.
# - KVNODE_MAX_CLIENT_BODY_BYTES: client write/transaction body limit.
# - KVNODE_MAX_PEER_BODY_BYTES: peer replication body limit.
# - KVNODE_MAX_ADMIN_BODY_BYTES: administrative body limit.
# - KVNODE_MAX_SCAN_LIMIT: maximum rows returned by one scan request.
# - KVNODE_TLS_ARGS: optional zero-or-more TLS flags for kvnode. TLS here is
#   transport configuration only; it does not add application authz/authn.

# Example three-node cluster topology:
#   node1: id 1, peer URL http://kvnode-1.example.internal:19091,
#          env path /etc/kvnode/node1.env, data /var/lib/kvnode/node1
#   node2: id 2, peer URL http://kvnode-2.example.internal:19091,
#          env path /etc/kvnode/node2.env, data /var/lib/kvnode/node2
#   node3: id 3, peer URL http://kvnode-3.example.internal:19091,
#          env path /etc/kvnode/node3.env, data /var/lib/kvnode/node3
# If multiple instances share one host, use distinct listener ports and update
# every peer URL accordingly.

KVNODE_ID=1
KVNODE_CLIENT_LISTEN=0.0.0.0:19090
KVNODE_PEER_LISTEN=0.0.0.0:19091
KVNODE_ADMIN_LISTEN=127.0.0.1:19092
KVNODE_DATA_DIR=/var/lib/kvnode/node1
KVNODE_PEERS=1=http://kvnode-1.example.internal:19091,2=http://kvnode-2.example.internal:19091,3=http://kvnode-3.example.internal:19091
KVNODE_REQUEST_DEADLINE_MS=5000
KVNODE_PEER_DEADLINE_MS=2000
KVNODE_MAX_CLIENT_BODY_BYTES=1048576
KVNODE_MAX_PEER_BODY_BYTES=1048576
KVNODE_MAX_ADMIN_BODY_BYTES=65536
KVNODE_MAX_SCAN_LIMIT=1000
KVNODE_TLS_ARGS=

# For /etc/kvnode/node2.env, keep the common limits/deadlines/peers above and
# change these per-instance values:
# KVNODE_ID=2
# KVNODE_DATA_DIR=/var/lib/kvnode/node2
# Optional if binding to a specific host address instead of 0.0.0.0:
# KVNODE_CLIENT_LISTEN=10.0.0.12:19090
# KVNODE_PEER_LISTEN=10.0.0.12:19091
# KVNODE_ADMIN_LISTEN=127.0.0.1:19092

# For /etc/kvnode/node3.env, keep the common limits/deadlines/peers above and
# change these per-instance values:
# KVNODE_ID=3
# KVNODE_DATA_DIR=/var/lib/kvnode/node3
# Optional if binding to a specific host address instead of 0.0.0.0:
# KVNODE_CLIENT_LISTEN=10.0.0.13:19090
# KVNODE_PEER_LISTEN=10.0.0.13:19091
# KVNODE_ADMIN_LISTEN=127.0.0.1:19092

# Optional TLS transport example. If enabled, set cert and key together and use
# https:// peer URLs in KVNODE_PEERS where appropriate for the configured node.
# KVNODE_TLS_ARGS="-tls-cert=/etc/kvnode/tls/node1.crt -tls-key=/etc/kvnode/tls/node1.key -tls-ca=/etc/kvnode/tls/ca.crt"
