{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gosuda.org/moreconsensus/schemas/target-incident-evidence-1.0.json",
  "title": "Target incident response evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "record_mode",
    "claim",
    "target",
    "participants",
    "release_provenance",
    "opened_at",
    "closed_at",
    "recorded_at",
    "valid_until",
    "scenarios",
    "raw_artifacts",
    "follow_up_actions",
    "sign_off"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "record_kind": { "const": "target-incident-evidence" },
    "record_mode": { "enum": ["target", "synthetic-test"] },
    "claim": { "type": "string", "minLength": 1 },
    "target": { "$ref": "#/$defs/target" },
    "participants": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/participant" }
    },
    "release_provenance": { "$ref": "#/$defs/releaseProvenance" },
    "opened_at": { "$ref": "#/$defs/utcTimestamp" },
    "closed_at": { "$ref": "#/$defs/utcTimestamp" },
    "recorded_at": { "$ref": "#/$defs/utcTimestamp" },
    "valid_until": { "$ref": "#/$defs/utcTimestamp" },
    "scenarios": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "raw_artifacts": {
      "type": "array",
      "minItems": 15,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/rawArtifact" }
    },
    "follow_up_actions": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/followUp" }
    },
    "sign_off": { "$ref": "#/$defs/signOff" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "artifactReferences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "environment", "service", "cluster_id"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmpty" },
        "environment": { "$ref": "#/$defs/nonEmpty" },
        "service": { "$ref": "#/$defs/nonEmpty" },
        "cluster_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_id", "name", "role", "organization"],
      "properties": {
        "participant_id": { "$ref": "#/$defs/identifier" },
        "name": { "$ref": "#/$defs/nonEmpty" },
        "role": { "$ref": "#/$defs/nonEmpty" },
        "organization": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "releaseProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_id",
        "source_repository",
        "source_revision",
        "source_tree",
        "binary_path",
        "binary_sha256",
        "built_at"
      ],
      "properties": {
        "release_id": { "$ref": "#/$defs/identifier" },
        "source_repository": { "$ref": "#/$defs/nonEmpty" },
        "source_revision": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
        },
        "source_tree": { "const": "clean" },
        "binary_path": { "$ref": "#/$defs/nonEmpty" },
        "binary_sha256": { "$ref": "#/$defs/sha256" },
        "built_at": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "scenarioParticipant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_id", "incident_role"],
      "properties": {
        "participant_id": { "$ref": "#/$defs/identifier" },
        "incident_role": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal", "detected_at", "evidence_artifact_ids"],
      "properties": {
        "signal": { "$ref": "#/$defs/nonEmpty" },
        "detected_at": { "$ref": "#/$defs/utcTimestamp" },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "triage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rationale", "decided_at", "decision_maker_participant_id"],
      "properties": {
        "decision": { "$ref": "#/$defs/nonEmpty" },
        "rationale": { "$ref": "#/$defs/nonEmpty" },
        "decided_at": { "$ref": "#/$defs/utcTimestamp" },
        "decision_maker_participant_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "mitigationAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "action_type",
        "exact_action",
        "target",
        "result",
        "evidence_artifact_ids"
      ],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "action_type": {
          "enum": [
            "command",
            "config-change",
            "traffic-control",
            "process-control",
            "storage-operation",
            "access-control",
            "observe-only"
          ]
        },
        "exact_action": { "$ref": "#/$defs/nonEmpty" },
        "target": { "$ref": "#/$defs/nonEmpty" },
        "result": { "enum": ["succeeded", "failed", "aborted"] },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_reference",
        "approver_participant_ids",
        "approved_at",
        "decision",
        "abort_criteria"
      ],
      "properties": {
        "approval_reference": { "type": ["string", "null"], "minLength": 1 },
        "approver_participant_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "approved_at": {
          "oneOf": [
            { "$ref": "#/$defs/utcTimestamp" },
            { "type": "null" }
          ]
        },
        "decision": { "enum": ["approved", "denied", "not-required"] },
        "abort_criteria": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmpty" }
        }
      }
    },
    "mitigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions",
        "executor_participant_id",
        "scope",
        "live_action",
        "started_at",
        "completed_at",
        "change_reference",
        "authorization"
      ],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/mitigationAction" }
        },
        "executor_participant_id": { "$ref": "#/$defs/identifier" },
        "scope": { "$ref": "#/$defs/nonEmpty" },
        "live_action": { "type": "boolean" },
        "started_at": { "$ref": "#/$defs/utcTimestamp" },
        "completed_at": { "$ref": "#/$defs/utcTimestamp" },
        "change_reference": { "$ref": "#/$defs/nonEmpty" },
        "authorization": { "$ref": "#/$defs/authorization" }
      },
      "allOf": [
        {
          "if": { "properties": { "live_action": { "const": true } } },
          "then": {
            "properties": {
              "authorization": {
                "properties": {
                  "approval_reference": { "type": "string", "minLength": 1 },
                  "approver_participant_ids": { "minItems": 1 },
                  "approved_at": { "$ref": "#/$defs/utcTimestamp" },
                  "decision": { "const": "approved" },
                  "abort_criteria": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    },
    "quorumDataSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked_at",
        "quorum_result",
        "data_safety_result",
        "method",
        "evidence_artifact_ids"
      ],
      "properties": {
        "checked_at": { "$ref": "#/$defs/utcTimestamp" },
        "quorum_result": { "enum": ["quorum-maintained", "quorum-restored"] },
        "data_safety_result": {
          "enum": ["no-data-loss", "restored-from-verified-backup"]
        },
        "method": { "$ref": "#/$defs/nonEmpty" },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "acceptanceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "result", "observed_at", "evidence_artifact_ids"],
      "properties": {
        "criterion": { "$ref": "#/$defs/nonEmpty" },
        "result": { "enum": ["pass", "fail"] },
        "observed_at": { "$ref": "#/$defs/utcTimestamp" },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "communicationEscalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "notified_at",
        "audience",
        "escalation_path",
        "message_summary",
        "evidence_artifact_ids"
      ],
      "properties": {
        "notified_at": { "$ref": "#/$defs/utcTimestamp" },
        "audience": { "$ref": "#/$defs/nonEmpty" },
        "escalation_path": { "$ref": "#/$defs/nonEmpty" },
        "message_summary": { "$ref": "#/$defs/nonEmpty" },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "recoveryEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recovered_at", "recovery_state", "validation", "evidence_artifact_ids"],
      "properties": {
        "recovered_at": { "$ref": "#/$defs/utcTimestamp" },
        "recovery_state": {
          "enum": ["service-restored", "threat-contained-service-restored"]
        },
        "validation": { "$ref": "#/$defs/nonEmpty" },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "result", "evidence_artifact_ids"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmpty" },
        "result": { "enum": ["pass", "fail"] },
        "evidence_artifact_ids": { "$ref": "#/$defs/artifactReferences" }
      }
    },
    "postIncidentCanaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked_at", "canaries"],
      "properties": {
        "checked_at": { "$ref": "#/$defs/utcTimestamp" },
        "canaries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/canary" }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "incident_class",
        "participants",
        "started_at",
        "ended_at",
        "detection",
        "triage",
        "mitigation",
        "quorum_data_safety",
        "acceptance_results",
        "communication_escalation",
        "recovery_evidence",
        "post_incident_canaries"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/identifier" },
        "incident_class": {
          "enum": [
            "storage_failure",
            "network_partition",
            "peer_compromise",
            "replay_checksum_suspicion",
            "recovery_stall"
          ]
        },
        "participants": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scenarioParticipant" }
        },
        "started_at": { "$ref": "#/$defs/utcTimestamp" },
        "ended_at": { "$ref": "#/$defs/utcTimestamp" },
        "detection": { "$ref": "#/$defs/detection" },
        "triage": { "$ref": "#/$defs/triage" },
        "mitigation": { "$ref": "#/$defs/mitigation" },
        "quorum_data_safety": { "$ref": "#/$defs/quorumDataSafety" },
        "acceptance_results": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/acceptanceResult" }
        },
        "communication_escalation": { "$ref": "#/$defs/communicationEscalation" },
        "recovery_evidence": { "$ref": "#/$defs/recoveryEvidence" },
        "post_incident_canaries": { "$ref": "#/$defs/postIncidentCanaries" }
      }
    },
    "rawArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "scenario_id", "kind", "path", "sha256", "captured_at"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/identifier" },
        "scenario_id": { "$ref": "#/$defs/identifier" },
        "kind": {
          "enum": [
            "raw-log",
            "raw-metric",
            "raw-command-output",
            "raw-communication",
            "raw-snapshot"
          ]
        },
        "path": { "$ref": "#/$defs/nonEmpty" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "captured_at": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "followUp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "scenario_id",
        "description",
        "owner_participant_id",
        "tracking_reference",
        "due_at",
        "status"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/identifier" },
        "scenario_id": { "$ref": "#/$defs/identifier" },
        "description": { "$ref": "#/$defs/nonEmpty" },
        "owner_participant_id": { "$ref": "#/$defs/identifier" },
        "tracking_reference": { "$ref": "#/$defs/nonEmpty" },
        "due_at": { "$ref": "#/$defs/utcTimestamp" },
        "status": { "enum": ["open", "closed"] }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_id", "role", "signed_at", "decision", "statement"],
      "properties": {
        "participant_id": { "$ref": "#/$defs/identifier" },
        "role": { "enum": ["operator", "independent-reviewer"] },
        "signed_at": { "$ref": "#/$defs/utcTimestamp" },
        "decision": { "enum": ["approved", "rejected"] },
        "statement": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "signOff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "independent_reviewer"],
      "properties": {
        "operator": { "$ref": "#/$defs/signature" },
        "independent_reviewer": { "$ref": "#/$defs/signature" }
      }
    }
  }
}
